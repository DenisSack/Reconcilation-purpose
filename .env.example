# Copier ce fichier vers .env et remplir les valeurs.
# Auth.js exige un secret non vide : sans AUTH_SECRET, l’app ne peut pas créer de session.

# Remplacer par votre vraie connexion PostgreSQL locale ou distante.
DATABASE_URL="postgresql://user:password@localhost:5432/luna_db"

# Obligatoire pour les sessions (32+ octets recommandés). Génération :
#   openssl rand -base64 32
AUTH_SECRET="A3+pJDOhEa9aWLq4/buWzLDQERkRy1LAclLRPGkxxy0="

# Optionnel (compat NextAuth v4) — si défini, utilisé si AUTH_SECRET est absent
NEXTAUTH_SECRET=""

NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# --- Docker Compose (TEST) ---
# Pour `docker compose up` : voir `.env.docker.example` → fichier `.env.docker` avec AUTH_SECRET + NEXTAUTH_URL (ex. http://localhost:3080).